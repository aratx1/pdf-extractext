{
  "name": "pdf-extractext",
  "version": "1.0.0",
  "description": "Extraer texto de un pdf que es proporcionado por el usuario. Después se hace un resumen gracias a un modelo de IA.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css",
