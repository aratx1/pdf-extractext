  "bugs": {
    "url": "https://github.com/aratx1/pdf-extractext/issues"
  },
  "homepage": "https://github.com/aratx1/pdf-extractext#readme",
  "devDependencies": {
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1"
  }
}
